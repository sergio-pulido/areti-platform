# ===========================================
# Areti Monorepo Environment Template
# Copy to .env and fill values for your env.
# ===========================================

# Runtime mode: development | test | production
NODE_ENV=development

# -----------------------------
# Core API/Web wiring
# -----------------------------
# API server port (apps/api)
API_PORT=4000

# Allowed origins for API CORS (comma-separated)
# Example: http://localhost:3000,https://app.example.com
CORS_ORIGINS=http://localhost:3000

# Canonical web URL used to generate email verification links
# Required in production.
WEB_APP_URL=http://localhost:3000

# API base URL consumed by web server-side calls
API_BASE_URL=http://localhost:4000

# API base URL exposed to browser-side calls in Next.js
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# -----------------------------
# Database
# -----------------------------
# SQLite path override (optional). If empty, project defaults are used.
# Dev default: data/areti.dev.db
# Test default: data/areti.test.db
# Prod default: data/areti.prod.db
ATARAXIA_DB_PATH=

# -----------------------------
# Passkeys (WebAuthn)
# -----------------------------
# Relying Party ID (domain only)
PASSKEY_RP_ID=localhost

# Relying Party display name shown in authenticator UX
PASSKEY_RP_NAME=Areti

# Allowed origins for passkey verification (comma-separated)
# Example: http://localhost:3000,https://app.example.com
PASSKEY_ORIGINS=http://localhost:3000

# -----------------------------
# Chat providers
# -----------------------------
# Priority order for provider fallback (comma-separated)
# Allowed values: deepseek,openai
CHAT_PROVIDER_ORDER=deepseek,openai

# DeepSeek provider
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_CHAT_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# OpenAI provider
OPENAI_API_KEY=your_openai_api_key
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional global system prompt override for Companion
# Leave empty to use built-in default doctrine prompt.
CHAT_GLOBAL_SYSTEM_PROMPT=

# Companion rolling-context controls (estimated token budget)
CHAT_CONTEXT_CAPACITY=24000
CHAT_CONTEXT_SUMMARIZE_PERCENT=70
CHAT_CONTEXT_WARNING_PERCENT=85
CHAT_CONTEXT_DEGRADED_PERCENT=95
CHAT_CONTEXT_RECENT_RAW_MESSAGES=12

# -----------------------------
# Reflections
# -----------------------------
# Optional local storage root for reflection audio assets.
# Defaults to data/reflection-audio when unset.
REFLECTION_STORAGE_PATH=

# Maximum accepted upload/record payload size in bytes.
REFLECTION_AUDIO_MAX_BYTES=10485760

# -----------------------------
# Email verification (Resend)
# -----------------------------
# Email transport for verification messages:
# - disabled (default for non-production)
# - resend (default for production)
# - smtp (useful for MailHog/local inbox capture)
EMAIL_TRANSPORT=disabled

# Required in production for signup verification delivery.
RESEND_API_KEY=your_resend_api_key

# Must be a verified sender/domain in Resend.
# Example: Areti <no-reply@yourdomain.com>
RESEND_FROM_EMAIL=Areti <no-reply@example.com>

# Optional SMTP transport settings (used when EMAIL_TRANSPORT=smtp).
# MailHog defaults:
# SMTP_HOST=localhost
# SMTP_PORT=1025
# SMTP_SECURE=false
SMTP_HOST=
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
